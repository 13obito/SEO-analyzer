# Database (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Redis (required for queued analysis unless ANALYSIS_USE_INLINE is set)
REDIS_URL="redis://127.0.0.1:6379"
# Or: REDIS_HOST=127.0.0.1 / REDIS_PORT=6379

# Resource isolation (optional overrides)
# ANALYSIS_MAX_PER_USER=2
# ANALYSIS_QUEUE_MAX_BACKLOG=100
# ANALYSIS_WORKER_CONCURRENCY=1
# ANALYSIS_GLOBAL_JOBS_PER_MINUTE=30

# Local dev only: run analysis inside the API process (no Redis/worker). Do not use in production or for stress tests.
# ANALYSIS_USE_INLINE=1
