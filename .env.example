# PostgreSQL (required). Examples:
# - Local: postgresql://USER:PASSWORD@localhost:5432/seo_analyzer
# - Neon / Vercel Postgres / Supabase: paste pooled URL from dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

NEXTAUTH_SECRET="generate-a-long-random-string"
# Production: exact site URL, no trailing slash
# NEXTAUTH_URL="https://seo-analyzer-4vyfvz2lz-gz-s-projects.vercel.app"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Redis + worker (local or separate host). On Vercel, VERCEL=1 defaults to inline analysis unless:
# ANALYSIS_USE_QUEUE=1 (you must run worker + Redis elsewhere)
# REDIS_URL="redis://127.0.0.1:6379"

# Force inline analysis on non-Vercel machines without Redis:
# ANALYSIS_USE_INLINE=1

# Heavy jobs on Hobby tier: set on Vercel env to avoid Chrome/timeouts if needed
# LIGHTHOUSE_DISABLED=1

# Optional: Google PageSpeed Insights API key — runs Lighthouse on Google's servers (no Chrome on Vercel).
# Enable "PageSpeed Insights API" in Google Cloud Console for the key.
# GOOGLE_PSI_API_KEY=""
